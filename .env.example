# Infrastruktur-Secrets (fachliche Config — FMG/iTop/DNS — liegt in der DB,
# konfigurierbar über das Web-UI unter Einstellungen).

# Pflicht (fail-closed: Stack startet ohne diese Werte nicht)
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me-long-random-string

# Initial-Passwort des beim ersten Start angelegten admin-Users
ADMIN_PASSWORD=admin

# Lab-Mitschnitt: 1 = alle FMG-Antworten als Fixtures aufzeichnen (Tests/Demo)
FMG_RECORD_FIXTURES=0

# Host-Ports des Webservices (Container lauscht intern weiter auf 80/443).
# Hoch gewählt, da der Docker-Host bereits 80/443 belegt.
HTTP_PORT=8766
HTTPS_PORT=8443
